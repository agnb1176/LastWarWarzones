// ================= HELPERS =================
function getLethalityTier(score){
  if(score >= 160) return {label:"T0 – War Machine", color:"red"};
  if(score >= 130) return {label:"T1 – High Threat", color:"orange"};
  if(score >= 100) return {label:"T2 – Competitive", color:"gold"};
  if(score >= 80) return {label:"T3 – Manageable", color:"cyan"};
  return {label:"T4 – Weak", color:"green"};
}

function highlightAlliance(a){
  const match = a.match(/(\d*\.?\d+)\s*([MB])(?=\s*kills)/i);
  if (!match) return a;

  let value = parseFloat(match[1]);
  if (match[2].toUpperCase() === 'B') value *= 1000;

  return value >= 300 ? a + ' 🔥' : a;
}

// ================= CORE RENDER =================
function renderZone(zone){

  let z = zoneData[zone];
  if(!z) return;

  let lethality = lethalityData[zone];

  if(lethality){
    const tier = getLethalityTier(lethality);

    document.getElementById("zoneLethality").innerHTML =
    `🔥 Lethality Score: <span style="color:${tier.color}">${lethality.toFixed(1)}</span>
    <br>⚠️ Threat Level: <span style="color:${tier.color}">${tier.label}</span>`;
  } else {
    document.getElementById("zoneLethality").innerHTML = "";
  }

  document.getElementById("zoneInfo").innerText =
    "📌 " + z.note;

  document.getElementById("zonePlayers").innerHTML =
    "<br><strong>🏰 Top 7 Alliances</strong><br>" +
    (z.alliances ? z.alliances.map(highlightAlliance).join("<br>") : "")
    + "<br><br><strong>👥 Top 15 Power</strong><br>" +
    (z.players ? z.players.join("<br>") : "N/A")
    + (z.heroPower
      ? "<br><br><strong>🧬 Top 15 Hero Power</strong><br>" + z.heroPower.join("<br>")
      : "");
}

// ================= DROPDOWN =================
document.getElementById("zoneSelect").addEventListener("change", function(){
  renderZone(this.value);
});

// ================= CHART =================
window.addEventListener("load", function(){

  if (typeof Chart === "undefined") return;

  new Chart(document.getElementById('chart'), {
    type: 'bar',
    data: {
      labels: ["1097","1133","1111","1149","1120","1070","1170"],
      datasets: [
